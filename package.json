{
  "name": "@tjlastnumber/skill-cli",
  "version": "0.2.0",
  "description": "Local skill manager CLI for coding tools",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "skill": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:manual": "bash docs/manual-verify.sh",
    "prepublishOnly": "pnpm test && pnpm build",
    "release:check": "pnpm test && pnpm build && npm pack --dry-run"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "docs/PRD.md",
    "docs/TODO.md"
  ],
  "dependencies": {
    "commander": "^14.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
